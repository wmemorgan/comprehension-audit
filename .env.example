# Required — LLM Provider
LLM_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-20250514

# Optional — Email Provider (Brevo)
# Remove or leave empty to use ConsoleRouter (no email integration)
EMAIL_API_KEY=your-brevo-api-key-here
EMAIL_LIST_IDS=comma-separated-list-ids

# Optional — Pipeline Webhook
# Remove or leave empty to skip webhook notifications
PIPELINE_WEBHOOK_URL=https://your-webhook-endpoint.com/audit-results

# Optional — Frontend
REPORT_BASE_URL=http://localhost:4321/audit/reports
PUBLIC_AUDIT_API_URL=/api/audit-submit

# Optional — CORS
ALLOWED_ORIGIN=http://localhost:4321
